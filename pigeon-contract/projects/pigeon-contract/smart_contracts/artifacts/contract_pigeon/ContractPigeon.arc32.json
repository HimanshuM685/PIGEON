    "contract": {
        "name": "ContractPigeon",
        "methods": [
            {
                "name": "createApplication",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Called automatically on application creation.\nRecords the creator as the contract admin."
            },
            {
                "name": "onboardUser",
                "args": [
                    {
                        "type": "string",
                        "name": "phone",
                        "desc": "Normalised phone number (digits only)"
                    },
                    {
                        "type": "string",
                        "name": "address",
                        "desc": "Algorand wallet address generated during onboarding"
                    },
                    {
                        "type": "string",
                        "name": "encryptedMnemonic",
                        "desc": "AES-256-GCM encrypted mnemonic (base64 string)"
                    },
                    {
                        "type": "uint64",
                        "name": "createdAt",
                        "desc": "Unix timestamp of onboarding"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Register a new user on-chain.\n\nMirrors `insertOnboardedUser()` from the backend.\nThe caller must be the admin and must supply enough MBR to cover\nthe new box (box cost = 2500 + 400 \u00d7 (keyLen + valueLen) micro-Algos)."
            },
            {
                "name": "onboardTelegramUser",
                "args": [
                    {
                        "type": "string",
                        "name": "telegramId",
                        "desc": "Telegram user ID (numeric string)"
                    },
                    {
                        "type": "string",
                        "name": "address",
                        "desc": "Algorand wallet address"
                    },
                    {
                        "type": "string",
                        "name": "encryptedMnemonic",
                        "desc": "AES-256-GCM encrypted mnemonic"
                    },
                    {
                        "type": "uint64",
                        "name": "createdAt",
                        "desc": "Unix timestamp"
                    },
                    {
                        "type": "string",
                        "name": "telegramHandle",
                        "desc": "Telegram"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Register a new user on-chain via Telegram identity.\n\nCreates both the user record (keyed by synthetic phone = \"tg_\" + telegramId)\nand the Telegram ID \u2192 phone mapping."
            },
            {
                "name": "linkTelegram",
                "args": [
                    {
                        "type": "string",
                        "name": "telegramId",
                        "desc": "Telegram user ID (numeric string)"
                    },
                    {
                        "type": "string",
                        "name": "phone",
                        "desc": "Phone number of the already-onboarded user"
                    },
                    {
                        "type": "string",
                        "name": "telegramHandle",
                        "desc": "Telegram"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Link a Telegram user ID to an existing phone-based user record.\nAlso stores the Telegram handle on the user record."
            },
            {
                "name": "updateUser",
                "args": [
                    {
                        "type": "string",
                        "name": "phone",
                        "desc": "Phone number (must already be onboarded)"
                    },
                    {
                        "type": "string",
                        "name": "address",
                        "desc": "New Algorand wallet address"
                    },
                    {
                        "type": "string",
                        "name": "encryptedMnemonic",
                        "desc": "New encrypted mnemonic"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Update an existing user's data.\n\nUseful if the backend needs to rotate keys or change the address."
            },
            {
                "name": "deleteUser",
                "args": [
                    {
                        "type": "string",
                        "name": "phone"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Remove a user from on-chain storage.\nDeletes the box and decrements the user counter."
            },
            {
                "name": "getUser",
                "args": [
                    {
                        "type": "string",
                        "name": "phone"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "(string,string,uint64,string)"
                },
                "desc": "Retrieve full user record.\nMirrors `findOnboardedUser()` from the backend."
            },
            {
                "name": "userExists",
                "args": [
                    {
                        "type": "string",
                        "name": "phone"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "bool"
                },
                "desc": "Check whether a phone number has been onboarded."
            },
            {
                "name": "getUserAddress",
                "args": [
                    {
                        "type": "string",
                        "name": "phone"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "string"
                },
                "desc": "Return only the Algorand address for a given phone.\nMirrors the `get_address` intent from the backend."
            },
            {
                "name": "getTotalUsers",
                "args": [],
                "readonly": false,
                "returns": {
                    "type": "uint64"
                },
                "desc": "Return the current total-users counter."
            },
            {
                "name": "getTelegramPhone",
                "args": [
                    {
                        "type": "string",
                        "name": "telegramId"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "string"
                },
                "desc": "Get the phone number linked to a Telegram user ID."
            },
            {
                "name": "telegramExists",
                "args": [
                    {
                        "type": "string",
                        "name": "telegramId"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "bool"
                },
                "desc": "Check whether a Telegram user ID is linked."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
}