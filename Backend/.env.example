# OpenRouter API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Algorand (TestNet) — for sending transactions. No KMD required.
ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
ALGOD_PORT=

# Optional: server port (default 3000)
PORT=3000

# ── On-Chain Storage (ContractPigeon) ──────────────────────────────────────
# App ID of the deployed ContractPigeon smart contract
PIGEON_APP_ID=0

# Admin/deployer mnemonic (25-word Algorand mnemonic).
# Used ONLY to sign contract calls (onboardUser, etc.) — NOT for user wallets.
ADMIN_MNEMONIC=

# SMSGate configuration (https://sms-gate.app/)
# API URL — set this if you're self-hosting SMSGate
# Default: https://api.sms-gate.app
SMSGATE_BASE_URL=https://api.sms-gate.app
SMSGATE_USERNAME=your_smsgate_username
SMSGATE_PASSWORD=your_smsgate_password


# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
